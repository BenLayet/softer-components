{
  "compilerOptions": {
    "tsBuildInfoFile": "node_modules/.tmp/tsconfig.tsbuildinfo",
    "target": "ES2020",
    "useDefineForClassFields": true,
    "lib": ["ES2020", "DOM", "DOM.Iterable"],
    "module": "ES2020",
    "skipLibCheck": true,

    /* Bundler mode */
    "moduleResolution": "bundler",
    "allowImportingTsExtensions": false,
    "isolatedModules": true,
    "moduleDetection": "force",
    "noEmit": true,
    "jsx": "react-jsx",
    "resolveJsonModule": true,

    /* Linting */
    "strict": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "noFallthroughCasesInSwitch": true,
    "noUncheckedSideEffectImports": true,
    "types": ["vitest/globals"],
    "paths": {
      "@softer-components/types": ["../../../types/src"],
      "@softer-components/base-adapter": ["../../../adapters/base-adapter/src"],
      "@softer-components/app-utilities": [
        "../../../utilities/app-utilities/src"
      ],
      "@softer-components/redux-adapter": [
        "../../../adapters/redux-adapter/src"
      ],
      "@softer-components/test-utilities": [
        "../../../utilities/test-utilities/src"
      ]
    }
  },
  "include": ["src", "test"]
}
